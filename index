<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Время менеджеров</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;700&family=Unbounded:wght@300;600&display=swap');

  :root {
    --bg: #000000;
    --card: #0a0a0a;
    --border: #1a1a1a;
    --accent-msk: #ff6d1f;
    --accent-irk: #3b9eff;
    --text: #e8eaf0;
    --muted: #4a5068;
    --mono: 'JetBrains Mono', monospace;
    --display: 'Unbounded', sans-serif;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--mono);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 24px;
    gap: 14px;
  }

  body::before { display: none; }

  .wrapper {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    width: 100%;
    max-width: 520px;
  }

  .label-top {
    font-family: var(--display);
    font-size: 10px;
    font-weight: 300;
    letter-spacing: 0.25em;
    color: var(--muted);
    text-transform: uppercase;
  }

  .card {
    width: 100%;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 22px 28px;
    display: flex;
    flex-direction: column;
    gap: 4px;
    position: relative;
    overflow: hidden;
  }

  .card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    border-radius: 16px 16px 0 0;
  }
  .card.msk::before { background: var(--accent-msk); }
  .card.irk::before { background: var(--accent-irk); }

  .city-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .city {
    font-family: var(--display);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }
  .card.msk .city { color: var(--accent-msk); }
  .card.irk .city { color: var(--accent-irk); }

  .tz-badge {
    font-size: 10px;
    color: var(--muted);
    background: var(--bg);
    border: 1px solid var(--border);
    padding: 2px 8px;
    border-radius: 4px;
  }

  .time-display {
    font-size: 58px;
    font-weight: 700;
    letter-spacing: -2px;
    line-height: 1;
    margin: 2px 0;
    font-variant-numeric: tabular-nums;
  }

  .seconds {
    font-size: 26px;
    color: var(--muted);
    font-weight: 300;
  }

  .date-row {
    font-size: 11px;
    color: var(--muted);
  }

  .delta {
    position: absolute;
    bottom: 22px;
    right: 28px;
    font-size: 11px;
    color: var(--muted);
  }

  .divider {
    display: flex;
    align-items: center;
    gap: 12px;
    width: 100%;
  }
  .divider-line { flex: 1; height: 1px; background: var(--border); }
  .divider-text {
    font-size: 10px;
    color: var(--muted);
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  /* ===== SLIDER BLOCK ===== */
  .slider-block {
    width: 100%;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 18px 22px 20px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .slider-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .slider-title {
    font-size: 10px;
    color: var(--muted);
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  .reset-btn {
    font-family: var(--mono);
    font-size: 10px;
    color: #44cc66;
    background: var(--bg);
    border: 1px solid #44cc66;
    border-radius: 6px;
    padding: 4px 12px;
    cursor: pointer;
    letter-spacing: 0.05em;
    transition: all 0.2s;
  }
  .reset-btn.paused {
    color: var(--accent-msk);
    border-color: var(--accent-msk);
  }

  /* Track */
  .track-wrap {
    position: relative;
    width: 100%;
    height: 52px;
    display: flex;
    align-items: center;
    cursor: grab;
    user-select: none;
    touch-action: none;
  }
  .track-wrap:active { cursor: grabbing; }

  .track-bg {
    position: absolute;
    left: 0; right: 0;
    height: 6px;
    background: var(--bg);
    border-radius: 3px;
    border: 1px solid var(--border);
    overflow: hidden;
  }

  .track-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--accent-msk), #ffaa60);
    border-radius: 3px;
    will-change: width;
  }

  .thumb {
    position: absolute;
    width: 36px;
    height: 36px;
    background: var(--accent-msk);
    border-radius: 50%;
    box-shadow: 0 0 0 5px rgba(255,109,31,0.18), 0 3px 14px rgba(0,0,0,0.5);
    display: flex;
    align-items: center;
    justify-content: center;
    transform: translateX(-50%);
    transition: box-shadow 0.15s;
    cursor: grab;
    will-change: left;
  }
  .thumb.dragging {
    cursor: grabbing;
    box-shadow: 0 0 0 10px rgba(255,109,31,0.12), 0 3px 18px rgba(0,0,0,0.6);
    transform: translateX(-50%) scale(1.08);
  }

  .thumb svg { pointer-events: none; }

  /* Ticks */
  .ticks {
    display: flex;
    justify-content: space-between;
    padding: 0 0;
  }
  .tick {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
  }
  .tick-line { width: 1px; height: 5px; background: var(--border); }
  .tick-label { font-size: 9px; color: var(--muted); }

  /* Work bar */
  .work-bar {
    position: relative;
    height: 18px;
    background: var(--bg);
    border-radius: 4px;
    border: 1px solid var(--border);
    overflow: hidden;
  }
  .seg {
    position: absolute;
    top: 0; bottom: 0;
  }
  .seg-irk  { background: rgba(59,158,255,0.25); }
  .seg-msk  { background: rgba(255,109,31,0.25); }
  .seg-both { background: rgba(100,210,120,0.35); }
  .cursor-now {
    position: absolute;
    top: 0; bottom: 0;
    width: 2px;
    background: white;
    border-radius: 1px;
    will-change: left;
  }

  .legend {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }
  .legend-item {
    display: flex;
    align-items: center;
    gap: 5px;
    font-size: 9px;
    color: var(--muted);
  }
  .ldot {
    width: 8px; height: 8px;
    border-radius: 2px;
  }
  .d-msk  { background: rgba(255,109,31,0.5); }
  .d-irk  { background: rgba(59,158,255,0.5); }
  .d-both { background: rgba(100,210,120,0.45); }

  @keyframes blink { 0%,100%{opacity:1} 50%{opacity:.25} }
  .live-dot {
    display: inline-block;
    width: 6px; height: 6px;
    background: #44cc66;
    border-radius: 50%;
    animation: blink 2s infinite;
    margin-right: 6px;
    vertical-align: middle;
  }
  .live-dot.paused { background: var(--accent-msk); animation: none; }
</style>
</head>
<body>
<div class="wrapper">
  <img src="data:image/png;base64," style="width:200px; height:auto; object-fit:contain; margin-bottom:2px;" alt="Mentori">
  <div class="label-top">
    <span class="live-dot" id="live-dot"></span>время менеджеров
  </div>

  <!-- MSK -->
  <div class="card msk">
    <div class="city-row">
      <span class="city">Москва</span>
      <span class="tz-badge">UTC+3</span>
    </div>
    <div class="time-display" id="time-msk">--:--</div>
    <div class="date-row" id="date-msk"></div>
    <div class="delta">базовый</div>
  </div>

  <div class="divider">
    <div class="divider-line"></div>
    <div class="divider-text">+5 часов</div>
    <div class="divider-line"></div>
  </div>

  <!-- IRK -->
  <div class="card irk">
    <div class="city-row">
      <span class="city">Иркутск</span>
      <span class="tz-badge">UTC+8</span>
    </div>
    <div class="time-display" id="time-irk">--:--</div>
    <div class="date-row" id="date-irk"></div>
    <div class="delta">менеджер</div>
  </div>

  <!-- SLIDER -->
  <div class="slider-block">
    <div class="slider-header">
      <span class="slider-title">крутилка · мск</span>
      <button class="reset-btn" id="reset-btn" onclick="resetLive()">● live</button>
    </div>

    <div class="track-wrap" id="track-wrap">
      <div class="track-bg">
        <div class="track-fill" id="track-fill" style="width:0%"></div>
      </div>
      <div class="thumb" id="thumb" style="left:0%">
        <svg width="14" height="10" viewBox="0 0 14 10" fill="none">
          <rect y="0" width="14" height="2" rx="1" fill="white"/>
          <rect y="4" width="14" height="2" rx="1" fill="white"/>
          <rect y="8" width="14" height="2" rx="1" fill="white"/>
        </svg>
      </div>
    </div>

    <div class="ticks">
      <div class="tick"><div class="tick-line"></div><span class="tick-label">00</span></div>
      <div class="tick"><div class="tick-line"></div><span class="tick-label">03</span></div>
      <div class="tick"><div class="tick-line"></div><span class="tick-label">06</span></div>
      <div class="tick"><div class="tick-line"></div><span class="tick-label">09</span></div>
      <div class="tick"><div class="tick-line"></div><span class="tick-label">12</span></div>
      <div class="tick"><div class="tick-line"></div><span class="tick-label">15</span></div>
      <div class="tick"><div class="tick-line"></div><span class="tick-label">18</span></div>
      <div class="tick"><div class="tick-line"></div><span class="tick-label">21</span></div>
      <div class="tick"><div class="tick-line"></div><span class="tick-label">23</span></div>
    </div>

    <div class="work-bar" id="work-bar">
      <div class="cursor-now" id="cursor-now"></div>
    </div>

    <div class="legend">
      <div class="legend-item"><div class="ldot d-msk"></div>Москва 9–18</div>
      <div class="legend-item"><div class="ldot d-irk"></div>Иркутск 9–18</div>
      <div class="legend-item"><div class="ldot d-both"></div>Оба онлайн</div>
    </div>
  </div>
</div>

<script>
  const DAYS   = ['вс','пн','вт','ср','чт','пт','сб'];
  const MONTHS = ['янв','фев','мар','апр','май','июн','июл','авг','сен','окт','ноя','дек'];
  const pad = n => String(n).padStart(2,'0');

  let isLive = true;
  let manualMins = 0; // 0..1439 MSK minutes from midnight
  let dragging = false;

  // DOM refs
  const timeMsk   = document.getElementById('time-msk');
  const dateElMsk = document.getElementById('date-msk');
  const timeIrk   = document.getElementById('time-irk');
  const dateElIrk = document.getElementById('date-irk');
  const trackWrap = document.getElementById('track-wrap');
  const thumb     = document.getElementById('thumb');
  const trackFill = document.getElementById('track-fill');
  const cursorNow = document.getElementById('cursor-now');
  const liveDot   = document.getElementById('live-dot');
  const resetBtn  = document.getElementById('reset-btn');

  // Get MSK now as Date
  function getMskNow() {
    const now = new Date();
    return new Date(now.getTime() + (now.getTimezoneOffset() + 180) * 60000);
  }

  function formatDate(d) {
    return `${DAYS[d.getDay()]}, ${d.getDate()} ${MONTHS[d.getMonth()]} ${d.getFullYear()}`;
  }

  function updateUI(mskH, mskM, mskS, mskDate) {
    // MSK
    const secPart = (mskS !== null) ? `<span class="seconds">:${pad(mskS)}</span>` : '';
    timeMsk.innerHTML = `${pad(mskH)}:${pad(mskM)}${secPart}`;
    dateElMsk.textContent = formatDate(mskDate);

    // IRK = MSK + 5h
    const irkTotalMins = mskH * 60 + mskM + 300;
    const irkH = Math.floor(irkTotalMins / 60) % 24;
    const irkM = irkTotalMins % 60;
    timeIrk.innerHTML = `${pad(irkH)}:${pad(irkM)}`;
    const irkDate = new Date(mskDate.getTime() + 5 * 3600000);
    dateElIrk.textContent = formatDate(irkDate);

    // thumb + fill + cursor
    const ratio = (mskH * 60 + mskM) / 1439;
    const pct = (ratio * 100).toFixed(3) + '%';
    thumb.style.left = pct;
    trackFill.style.width = pct;
    cursorNow.style.left = pct;
  }

  function tick() {
    if (!isLive) return;
    const msk = getMskNow();
    manualMins = msk.getHours() * 60 + msk.getMinutes();
    updateUI(msk.getHours(), msk.getMinutes(), msk.getSeconds(), msk);
  }

  function applyManual(mins) {
    manualMins = Math.max(0, Math.min(1439, mins));
    const h = Math.floor(manualMins / 60);
    const m = manualMins % 60;
    const msk = getMskNow();
    const fakeDate = new Date(msk);
    fakeDate.setHours(h, m, 0, 0);
    updateUI(h, m, null, fakeDate);
  }

  function setPaused() {
    isLive = false;
    liveDot.classList.add('paused');
    resetBtn.classList.add('paused');
    resetBtn.textContent = '↺ сейчас';
  }

  function resetLive() {
    isLive = true;
    liveDot.classList.remove('paused');
    resetBtn.classList.remove('paused');
    resetBtn.textContent = '● live';
    tick();
  }

  // Drag helpers
  function clientXToMins(clientX) {
    const rect = trackWrap.getBoundingClientRect();
    const ratio = Math.max(0, Math.min(1, (clientX - rect.left) / rect.width));
    return Math.round(ratio * 1439);
  }

  function onDragStart(clientX) {
    dragging = true;
    thumb.classList.add('dragging');
    setPaused();
    applyManual(clientXToMins(clientX));
  }

  function onDragMove(clientX) {
    if (!dragging) return;
    applyManual(clientXToMins(clientX));
  }

  function onDragEnd() {
    dragging = false;
    thumb.classList.remove('dragging');
  }

  // Mouse events
  trackWrap.addEventListener('mousedown', e => { e.preventDefault(); onDragStart(e.clientX); });
  document.addEventListener('mousemove', e => { if (dragging) onDragMove(e.clientX); });
  document.addEventListener('mouseup', onDragEnd);

  // Touch events
  trackWrap.addEventListener('touchstart', e => {
    e.preventDefault();
    onDragStart(e.touches[0].clientX);
  }, { passive: false });
  document.addEventListener('touchmove', e => {
    if (dragging) { e.preventDefault(); onDragMove(e.touches[0].clientX); }
  }, { passive: false });
  document.addEventListener('touchend', onDragEnd);

  // Build work bar segments
  // MSK 9-18 local, IRK 9-18 IRK = MSK 4-13
  function buildWorkBar() {
    const bar = document.getElementById('work-bar');
    const segs = [
      { s: 4, e: 9, cls: 'seg-irk' },
      { s: 9, e: 13, cls: 'seg-both' },
      { s: 13, e: 18, cls: 'seg-msk' },
    ];
    segs.forEach(({s, e, cls}) => {
      const el = document.createElement('div');
      el.className = 'seg ' + cls;
      el.style.left  = (s / 24 * 100) + '%';
      el.style.width = ((e - s) / 24 * 100) + '%';
      bar.insertBefore(el, cursorNow);
    });
  }

  buildWorkBar();
  tick();
  setInterval(tick, 1000);
</script>
</body>
</html>
